{
  "name": "kunjing-desktop",
  "version": "1.0.0",
  "description": "昆仑镜桌面版 - AIGC 影视创作工具",
  "main": "electron/main.js",
  "scripts": {
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd frontend-src && npm install && npx nuxi generate",
    "build:electron": "tsc --project tsconfig.electron.json && electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.caiwansan.kunjing",
    "productName": "昆仑镜",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend-src/.output/public/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  }
}
