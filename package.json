{
  "name": "kunjing-desktop",
  "version": "1.0.0",
  "description": "昆仑镜桌面版 - AIGC 影视创作工具",
  "main": "electron/dist/main.js",
  "author": "caiwansan",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd frontend-src && npx nuxi build --prerender=false",
    "build:electron": "npx tsc --project tsconfig.electron.json",
    "package:linux": "npm run build:frontend && npm run build:electron && npx electron-builder --linux"
  },
  "build": {
    "appId": "com.caiwansan.kunjing",
    "productName": "昆仑镜",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "frontend-src/.output/public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend-src/setup",
        "to": "setup"
      }
    ],
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Video"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  }
}
